# Copy to config.env and fill with REAL values. config.env is gitignored.
#   cp config.env.example config.env && $EDITOR config.env
#
# All scripts source ./config.env. Nothing here is committed with real data.

# --- Bitbucket host (the broken one) ---
BB_HOST="bitbucket"                       # ssh-reachable name or IP of Bitbucket host
BB_VERSION="5.13.1"
BB_INSTALL="/opt/atlassian/bitbucket/${BB_VERSION}"
BB_JRE="${BB_INSTALL}/jre"                # bundled JRE (Oracle 1.8.0_172)
BB_HOME="/data/atlassian/application-data/bitbucket"
BB_MAIL_LOG="${BB_HOME}/log/atlassian-bitbucket-mail.log"
BB_APP_LOG="${BB_HOME}/log/atlassian-bitbucket.log"
BB_START_SCRIPT="${BB_INSTALL}/bin/_start-webapp.sh"
BB_INITD="/etc/rc.d/init.d/atlbitbucket"

# --- Reference working host: Jira (mail works through same relay) ---
JIRA_HOST="10.0.0.37"
JIRA_JRE="/opt/atlassian/jira/jre"        # Oracle 1.8.0_181

# --- Reference working host: Confluence (optional) ---
CONF_HOST="10.0.0.35"
CONF_JRE="/opt/atlassian/confluence/jre"  # AdoptOpenJDK 1.8.0_202

# --- SMTP relay ---
RELAY_HOST="mail.relay.example"           # e.g. msk.<domain>
RELAY_IP="10.0.0.1"
RELAY_PORT="587"
MAIL_USER="bitbucket@example"

# --- ssh user for reaching reference hosts from BB_HOST ---
SSH_USER="root"

# --- Replacement JRE for the swap scripts (10-jre-swap.sh / 11-jre-rollback.sh) ---
# Where to get the GOOD JRE from. One of:
#   * a local directory on the BB host that contains bin/java
#       NEW_JRE_SRC="/opt/atlassian/_jre-new"
#   * a local tarball (.tar.gz/.tgz) whose top level is a JRE dir
#       NEW_JRE_SRC="/root/jdk-11.0.22-jre.tar.gz"
#   * a remote   host:path   (rsync over ssh, read-only on the source)
#       NEW_JRE_SRC="${SSH_USER}@${JIRA_HOST}:${JIRA_JRE}"
# IMPORTANT: if the relay is TLS 1.3-only, the replacement MUST be 8u261+ or
# Java 11 — an older Java 8 JRE (e.g. Jira's 8u181) will NOT fix it.
NEW_JRE_SRC="${SSH_USER}@${JIRA_HOST}:${JIRA_JRE}"

# Permanent home for the staged replacement JRE on the BB host (never deleted
# by the swap; rollback leaves it in place for a quick re-swap).
NEW_JRE_STAGE="/opt/atlassian/_jre-new"
